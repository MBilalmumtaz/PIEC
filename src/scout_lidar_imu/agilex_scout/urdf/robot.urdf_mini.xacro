<?xml version="1.0"?>
<robot name="scout_mini" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- =========  same arguments that V2 uses  ========= -->
  <xacro:arg name="odometry_source" default="ground_truth"/>
  <xacro:arg name="load_gazebo"     default="true"/>
  <xacro:arg name="simulation"      default="true"/>
  <xacro:arg name="lidar_type"      default="3d"/>   <!-- 2d | 3d -->

  <!-- =========  base robot (kept as macro so we can pass args)  ========= -->
  <xacro:include filename="$(find agilex_scout)/urdf/mobile_robot/scout_mini.urdf.xacro"/>
  <xacro:scout_mini
        odometry_source="$(arg odometry_source)"
        load_gazebo="$(arg load_gazebo)"
        lidar_type="$(arg lidar_type)"/>

  <!-- =========  OS1 sensor (same as V2)  ========= -->
  <xacro:include filename="$(find agilex_scout)/urdf/sensors/os1.urdf"/>
  <joint name="os1_joint" type="fixed">
    <origin xyz="0.20 0.0 0.64" rpy="0 0 0"/>
    <parent link="mobile_robot_base_link"/>
    <child  link="os_sensor"/>
  </joint>

  <!-- =========  real-robot extras  ========= -->
  <xacro:unless value="$(arg simulation)">
    <!-- camera, GPS, etc. -->
  </xacro:unless>

</robot>
