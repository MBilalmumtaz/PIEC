<?xml version="1.0" encoding="utf-8"?>
<robot name="os1_description" xmlns:xacro="http://www.ros.org/wiki/xacro">

	<link name="os_sensor">
		<visual>
			<origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
			<geometry>
				<mesh filename="file://$(find agilex_scout)/meshes/sensors/laser_link.stl"
					scale="1.0 1.0 1.0" />
			</geometry>
			<material name="Gray">
				<color rgba="0.5 0.5 0.5 1" />
			</material>
		</visual>
	</link>

	<!-- IMU link -->
	<link name="imu_link">
		<inertial>
			<mass value="0.05"/>
			<origin xyz="0 0 0" rpy="0 0 0"/>
			<inertia ixx="1e-4" ixy="0" ixz="0"
			         iyy="1e-4" iyz="0" izz="1e-4"/>
		</inertial>
	</link>

	<!-- Fixed joint: mount IMU inside the LiDAR sensor -->
	<joint name="os_sensor_to_imu" type="fixed">
		<parent link="os_sensor"/>
		<child  link="imu_link"/>
		<origin xyz="0 0 0.02" rpy="0 0 0"/>
	</joint>

	<!-- Gazebo IMU sensor plugin -->
	<gazebo reference="imu_link">
		<sensor name="os1_imu" type="imu">
			<always_on>true</always_on>
			<update_rate>100</update_rate>
			<topic>scout/imu</topic>
			<ignition_frame_id>imu_link</ignition_frame_id>
			<imu>
				<angular_velocity_x_noise>0.005</angular_velocity_x_noise>
				<angular_velocity_y_noise>0.005</angular_velocity_y_noise>
				<angular_velocity_z_noise>0.005</angular_velocity_z_noise>
				<linear_acceleration_x_noise>0.05</linear_acceleration_x_noise>
				<linear_acceleration_y_noise>0.05</linear_acceleration_y_noise>
				<linear_acceleration_z_noise>0.05</linear_acceleration_z_noise>
			</imu>
		</sensor>
	</gazebo>

</robot>
